{
  "name": "ai-agent-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo funcional de orquestração multi-agente em TypeScript",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "verify:quick": "npm run lint && npm run test:unit && npm run test:smoke && npm run test:basic",
    "test": "vitest run",
    "test:unit": "vitest run tests/orchestrator.test.ts",
    "test:smoke": "vitest run tests/cli.smoke.test.ts",
    "test:basic": "vitest run tests/basic-example.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "agents",
    "orchestration",
    "typescript",
    "demo"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
